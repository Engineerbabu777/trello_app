{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "jsx": "react-jsx",
    "strict": true,
    "baseUrl": "./src",
    "paths": {
      "@/*": [
        "*"
      ],
      "@components/*": [
        "components/*"
      ],
      "@screens/*": [
        "screens/*"
      ],
      "@utils/*": [
        "utils/*"
      ],
      "@assets/*": [
        "../assets/*"
      ],
      "@database/*": [
        "database/*"
      ],
      "@constants/*": [
        "constants/*"
      ]
    },
    "types": [
      "expo-router/types"
    ],
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "strictPropertyInitialization": false,
    "useDefineForClassFields": false
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "nativewind-env.d.ts",
    "server/tsconfig.json",
    "commitlint.config.ts",
    "src/providers/internet-connection-provider.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
